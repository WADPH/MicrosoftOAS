# Main ----------------------------------------------------------------------
PORT=3000
TEAMS_OUTGOING_WEBHOOK_SECRET=  # Grab messages from Teams via Outgoing Webhook (https://yourapp.com/webhook/teams)

# Tenants (multi-tenant)
TENANTS=EIGROUP,WAVERITY  # Comma-separated list of tenant codes

# Tenant 1: EIGROUP
EIGROUP_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EIGROUP_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EIGROUP_CLIENT_SECRET=

# Tenant 2: WAVERITY
WAVERITY_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WAVERITY_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WAVERITY_CLIENT_SECRET=

# License usage location for new users created by the app (e.g. US, AZ, GB, etc.)
DEFAULT_USAGE_LOCATION=US

# SSO Configuration ----------------------------------------------------------------------

ALLOWED_EMAILS= # Comma-separated list of allowed email addresses for SSO login
SESSION_SECRET= # Secret key for session management (create and use a strong random string)
REDIRECT_URI= # The URI where the SSO provider will redirect after authentication (e.g. https://yourapp.com/auth/callback)

# Email Configurations ----------------------------------------------------------------------

MAIL_SENDER_UPN= # The User Principal Name (UPN) of the email account that will send emails (e.g. user@domain.com)
LICENSE_REQUEST_TO= # Email address to receive license request emails
LICENSE_REQUEST_CC= # Comma-separated list of email addresses to CC for license requests
ASSETS_REQUEST_TO= # Email address to receive asset request emails
ASSETS_REQUEST_CC= # Comma-separated list of email addresses to CC for asset requests



# Snipe-IT integration ----------------------------------------------------------------------
SNIPEIT_ENABLED=true 
SNIPEIT_URL= # Base URL of your Snipe-IT instance (e.g. https://inventory.yourdomain.com)
SNIPEIT_API_KEY= # API key for authenticating with Snipe-IT
SNIPEIT_LAPTOP_PREFIX=PC- # Prefix for laptop asset tags in Snipe-IT (for filtering)
SNIPEIT_MONITOR_PREFIX=MN- # Prefix for monitor asset tags in Snipe-IT (for filtering)

# Zammad integration ----------------------------------------------------------------------
ZAMMAD_ENABLED=true
ZAMMAD_URL=https://zammad.yourdomain.com
ZAMMAD_API_TOKEN=  # API token from Zammad
ZAMMAD_DEFAULT_CUSTOMER=  # Default customer email for tickets


# Debug ----------------------------------------------------------------------

TEST_RECIPIENT=  # Optional: if set, all outgoing emails will be sent to this address (useful for testing)
WEBHOOK_DEBUG=false  # Set to true only for debugging (disable in production)


# Company Matcher Configurations ----------------------------------------------------------------------

COMPANY_MATCHER_KEYS=COMPANY1,COMPANY2  # Comma-separated list of company keys for matching

# Company 1 Configuration
COMPANY_MATCHER_COMPANY1_PATTERNS=company1,company1llc  # Patterns to identify the company
COMPANY_MATCHER_COMPANY1_DOMAIN=company1.az            # Primary email domain
COMPANY_MATCHER_COMPANY1_CODE=C1                       # Short company code
COMPANY_MATCHER_COMPANY1_TENANT=EIGROUP                # Tenant to use (must be in TENANTS list)
COMPANY_MATCHER_COMPANY1_GROUPS=                       # Comma-separated group IDs (optional)

# Company 2 Configuration
COMPANY_MATCHER_COMPANY2_PATTERNS=company2,company2corp  # Patterns to identify the company
COMPANY_MATCHER_COMPANY2_DOMAIN=company2.az            # Primary email domain
COMPANY_MATCHER_COMPANY2_CODE=C2                       # Short company code
COMPANY_MATCHER_COMPANY2_TENANT=WAVERITY               # Tenant to use (must be in TENANTS list)
COMPANY_MATCHER_COMPANY2_GROUPS=                       # Comma-separated group IDs (optional)


