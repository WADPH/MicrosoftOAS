# Server
PORT=3000
TEAMS_OUTGOING_WEBHOOK_SECRET=base64_token_from_teams_outgoing_webhook

# Graph auth (multi-tenant)
TENANTS=EIGROUP
EIGROUP_TENANT_ID=your_tenant_id
EIGROUP_CLIENT_ID=your_client_id
EIGROUP_CLIENT_SECRET=your_client_secret

# Legacy single-tenant keys (optional fallback)
TENANT_ID=your_tenant_id
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
DEFAULT_USAGE_LOCATION=EN
REDIRECT_URI=http://localhost:3000/auth/callback
ALLOWED_EMAILS=admin@example.com
SESSION_SECRET=replace_with_strong_random_secret

# Sender mailbox (must exist)
MAIL_SENDER_UPN=bot@your-domain.com

# Production recipients
LICENSE_REQUEST_TO=one@example.com
LICENSE_REQUEST_CC=two@example.com,three@example.com
ASSETS_REQUEST_TO=four@example.com
ASSETS_REQUEST_CC=five@example.com,six@example.com

# Company Matcher Configurations 
COMPANY_MATCHER_KEYS=FIRST,SECOND,THIRD

# FIRST 
COMPANY_MATCHER_FIRST_PATTERNS=firstcompany,firstllc
COMPANY_MATCHER_FIRST_DOMAIN=first.com
COMPANY_MATCHER_FIRST_CODE=FIRST
COMPANY_MATCHER_FIRST_TENANT=EIGROUP
COMPANY_MATCHER_FIRST_GROUPS=

# SECOND
COMPANY_MATCHER_SECOND_PATTERNS=secondcompany,secondllc
COMPANY_MATCHER_SECOND_DOMAIN=second.com
COMPANY_MATCHER_SECOND_CODE=SECOND
COMPANY_MATCHER_SECOND_TENANT=EIGROUP
COMPANY_MATCHER_SECOND_GROUPS=

# THIRD
COMPANY_MATCHER_THIRD_PATTERNS=thirdcompany,thirdllc
COMPANY_MATCHER_THIRD_DOMAIN=third.com
COMPANY_MATCHER_THIRD_CODE=THIRD
COMPANY_MATCHER_THIRD_TENANT=EIGROUP
COMPANY_MATCHER_THIRD_GROUPS=

# Debug
# Safe test mode: if set, all outgoing mails go only here
#TEST_RECIPIENT=some.one@domain.ai
WEBHOOK_DEBUG=false

# Snipe-IT integration
SNIPEIT_ENABLED=false
SNIPEIT_URL=
SNIPEIT_API_KEY=
SNIPEIT_LAPTOP_PREFIX=PC-
SNIPEIT_MONITOR_PREFIX=MN-
